# Copy to .env and fill in real values.
PORT=8083
# replicaSet is required for multi-document transactions (see README);
# directConnection avoids replica-set discovery of the container-internal hostname.
MONGODB_URL=mongodb://localhost:27017/bookmyshow?replicaSet=rs0&directConnection=true
SECRET_KEY=your_jwt_secret_here
STRIPE_KEY=sk_test_your_stripe_test_secret_key
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_gmail_app_password
